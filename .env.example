# ============================================
# Bitrix24 Configuration
# ============================================

# Webhook Authentication (рекомендуется для простых интеграций)
# Формат: https://your-domain.bitrix24.ru/rest/user_id/webhook_key/
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your_webhook_key/

# OAuth Authentication (для приложений)
# BITRIX24_DOMAIN=your-domain.bitrix24.ru
# BITRIX24_CLIENT_ID=your_client_id
# BITRIX24_CLIENT_SECRET=your_client_secret
# BITRIX24_ACCESS_TOKEN=your_access_token
# BITRIX24_REFRESH_TOKEN=your_refresh_token

# SDK Settings
BITRIX24_API_VERSION=2  # 2 или 3
BITRIX24_TIMEOUT=10
BITRIX24_MAX_RETRIES=3

# ============================================
# AI Services
# ============================================

# OpenAI (GPT-4)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# AI Settings
DEFAULT_AI_MODEL=gpt-4
MAX_TOKENS=2000
TEMPERATURE=0.7

# ============================================
# 1C Integration
# ============================================

ONEC_BASE_URL=http://your-1c-server:port/base_name
ONEC_USERNAME=your_username
ONEC_PASSWORD=your_password

# ============================================
# Telegram Bots (опционально)
# ============================================

ANALYTICS_BOT_TOKEN=your_analytics_bot_token_here
SALES_BOT_TOKEN=your_sales_bot_token_here
SUPPORT_BOT_TOKEN=your_support_bot_token_here

# ============================================
# Application Settings
# ============================================

DEBUG=False
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
